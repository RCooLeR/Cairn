{
  "name": "cairn-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build:dev": "tsc --noEmit && vite build --configLoader runner --minify false --mode development",
    "build": "tsc --noEmit && vite build --configLoader runner --mode production",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "audit": "npm audit --audit-level=moderate",
    "test": "vitest run --configLoader runner",
    "test:release-ui": "playwright test --config playwright.config.mjs",
    "ladle": "ladle serve --host 127.0.0.1",
    "ladle:build": "ladle build",
    "build:release-ui": "tsc --noEmit && vite build --configLoader runner --mode release-validation",
    "preview": "vite preview"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@wailsio/runtime": "3.0.0-alpha.79",
    "@xterm/xterm": "^5.5.0",
    "lucide-react": "^0.555.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "zustand": "^5.0.14"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@ladle/react": "^5.1.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "dompurify": "^3.4.11",
    "@vitejs/plugin-react": "$@vitejs/plugin-react",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "vite": "$vite"
  }
}
