{
  "name": "cairn-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:dev": "tsc --noEmit && vite build --configLoader runner --minify false --mode development",
    "build": "tsc --noEmit && vite build --configLoader runner --mode production",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "audit": "npm audit --audit-level=moderate",
    "test": "vitest run --configLoader runner",
    "test:release-ui": "playwright test --config playwright.config.mjs",
    "ladle": "ladle serve --host 127.0.0.1",
    "ladle:build": "ladle build",
    "build:release-ui": "tsc --noEmit && vite build --configLoader runner --mode release-validation",
    "preview": "vite preview"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@wailsio/runtime": "3.0.0-alpha.79",
    "@xterm/xterm": "^5.5.0",
    "lucide-react": "^0.555.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.5.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.1",
    "@ladle/react": "^5.1.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.49.0",
    "vite": "^8.0.5",
    "vitest": "^4.0.15"
  },
  "overrides": {
    "dompurify": "^3.4.10",
    "@vitejs/plugin-react": "$@vitejs/plugin-react",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "vite": "$vite"
  }
}
