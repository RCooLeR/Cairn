<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="cairn.exe"
        Arguments=""
        InstallLocation="C:\Program Files\Cairn\Cairn">
    </Installer>
    <PackageInformation
        PackageName="Cairn"
        PackageDisplayName="Cairn"
        PublisherName="CN=Cairn"
        PublisherDisplayName="Cairn"
        Version="0.1.0.0"
        PackageDescription="A clean Compose-first Docker manager for Windows, macOS, and Linux">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="app.cairn.desktop"
                Description="A clean Compose-first Docker manager for Windows, macOS, and Linux"
                DisplayName="Cairn"
                ExecutableName="cairn.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Cairn</DisplayName>
            <PublisherDisplayName>Cairn</PublisherDisplayName>
            <Description>A clean Compose-first Docker manager for Windows, macOS, and Linux</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="cairn.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
